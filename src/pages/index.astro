---
import Layout from "../layouts/Layout.astro";
import MarathonHero from "@components/MarathonHero/index.astro";
import MarathonAbout from "@components/MarathonAbout/index.astro";
import MarathonProjects from "@components/MarathonProjects/index.astro";
import MarathonContact from "@components/MarathonContact/index.astro";
---

<Layout
    title="Renato Lagos — Backend Engineer · Python · AI · LLM Agents"
    description="Renato Lagos · Backend Engineer in Berlin. 4+ years of production Python (Django, FastAPI, PostgreSQL, AWS, Docker). AI-assisted development with Claude Code. Shipping multilingual Anthropic-powered agents for healthcare."
    activePath="/"
>
    <main>
        <MarathonHero />
        <MarathonAbout showExperience={false} />
        <MarathonProjects title="Featured Work" limit={6} sectionId="MOD::PROJECTS·FEATURED" />
        <MarathonContact />
    </main>
</Layout>
